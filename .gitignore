# Node.js 依赖包（几百 MB，每次安装可重新生成）
node_modules/
app/node_modules/

# Next.js 构建缓存
.next/
app/.next/

# 环境变量 / 密钥（绝对不能上传）
.env
.env.local
.env.production
.env.*.local
app/.env
app/.env.local
app/.env.production

# SQLite 数据库文件（内含真实业务数据）
*.db
*.sqlite
*.sqlite3

# 日志、编辑器临时文件、系统垃圾
*.log
.DS_Store
Thumbs.db
.vscode/
.idea/

# graphify 输出（可重新生成）
graphify-out/

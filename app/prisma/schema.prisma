// 九泰临研 V1 数据模型 — SQLite 版（dev）
// M7 部署切换：tsx scripts/switch-db.ts postgresql

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// F2 试验管理：试验主表
model ClinicalTrial {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  disease         String
  city            String
  phase           String?
  status          String   @default("recruiting")
  isPublic        Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  summary         String
  description     String?
  inclusionBrief  String?
  exclusionBrief  String?

  sponsor          String?
  intervention     String?
  studyDesign      String?
  targetEnrollment Int?
  siteName         String?
  siteAddress      String?
  contactPerson    String?
  contactPhone     String?
  benefits         String?
  followUpPlan     String?
  adVersion        String?
  adVersionDate    DateTime?
  ethicsApproval   String?
  qrcodeUrl        String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // M8.5 新增：弱关联 MediaAsset.id（不写 @relation 避免级联）
  coverMediaId    String?

  leads           Lead[]
  applications    Application[] @relation("TrialApplications")
  communityPosts  CommunityPost[] @relation("TrialPosts")

  // M8.2 反向关系
  prescreenForm   TrialPrescreenForm?

  @@index([status, isPublic])
  @@index([disease])
}

// F3 线索池：患者提交预筛后生成的线索
model Lead {
  id              String   @id @default(cuid())
  trialId         String
  trial           ClinicalTrial @relation(fields: [trialId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?    @relation("UserLeads", fields: [userId], references: [id])

  name            String
  phone           String
  gender          String?
  age             Int?
  city            String?
  condition       String?

  projectAnswers  String?

  agreePrivacy    Boolean  @default(false)
  agreeReuse      Boolean  @default(false)

  sourcePage      String?
  sourcePostId    String?

  status          String   @default("new")
  statusChangedAt DateTime @default(now())
  statusChangedBy String?
  note            String?

  application     Application? @relation("LeadApplication")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([trialId, status])
  @@index([status, createdAt])
  @@index([phone])
  @@index([userId, createdAt])
}

// B01 后台账号：operator / admin 两档，role 字段区分
model OperatorUser {
  id              String   @id @default(cuid())
  username        String   @unique
  passwordHash    String
  displayName     String
  role            String   @default("operator")
  status          String   @default("active")
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// M6 · 统一审计日志：记录后台关键写操作，便于追溯
model AuditLog {
  id                  String   @id @default(cuid())
  operatorId          String?
  operatorUsername    String?
  operatorDisplayName String?
  operatorRole        String?
  action              String
  entityType          String
  entityId            String?
  summary             String 
  detailJson          String?
  createdAt           DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([entityType, createdAt])
  @@index([operatorId, createdAt])
}

// M3 · 患者账号：手机号唯一
model User {
  id              String   @id @default(cuid())
  phone           String   @unique
  displayName     String?
  name            String?
  gender          String?
  age             Int?
  city            String?
  condition       String?
  agreeReuse      Boolean  @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // M8.3 扩展
  role              String    @default("patient")
  isSystemAi        Boolean   @default(false)
  symptomsText      String?
  aiDiseaseTags     String?
  symptomsUpdatedAt DateTime?
  lastMatchedAt     DateTime?

  // M8.5 新增
  welcomeTriggeredAt    DateTime?  // AI 欢迎消息触发幂等标记
  recommendDismissedAt  DateTime?  // 推荐分区弹窗"稍后再说"标记

  applications    Application[]
  leads           Lead[]   @relation("UserLeads")
  posts           CommunityPost[] @relation("UserPosts")
  comments        CommunityComment[] @relation("UserComments")

  // M8.1 反向关系：一名用户最多一条有效锁
  lock            AccountLock?

  // M8.3 反向关系
  medicalRecords   UserMedicalRecord[]
  groupMemberships UserGroupMembership[]
  matchSessions    MatchAssistantSession[]
}

// 短信验证码（一次性，10 分钟有效）
model SmsCode {
  id              String   @id @default(cuid())
  phone           String
  code            String
  expiresAt       DateTime
  consumedAt      DateTime?
  attempts        Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([phone, createdAt])
}

// M5 · 患者社区

model CommunityGroup {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  diseaseTag    String?
  introduction  String?
  isEnabled     Boolean  @default(true)
  sortOrder     Int      @default(100)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // M8.3 扩展
  headerImageUrl              String?
  recommendedDiseaseKeywords  String?
  allowAiComment              Boolean @default(true)
  allowDoctorComment          Boolean @default(true)

  // M8.5 新增：弱关联 MediaAsset.id（不写 @relation 避免级联）
  coverMediaId  String?

  posts         CommunityPost[]
  memberships   UserGroupMembership[]

  @@index([isEnabled, sortOrder])
}

model CommunityPost {
  id              String   @id @default(cuid())
  groupId         String
  group           CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  authorUserId    String?
  authorUser      User?    @relation("UserPosts", fields: [authorUserId], references: [id])
  authorRole      String   @default("patient")
  isAnonymous     Boolean  @default(false)

  title           String
  content         String 
  postType        String   @default("question")
  relatedTrialId  String?
  relatedTrial    ClinicalTrial? @relation("TrialPosts", fields: [relatedTrialId], references: [id])

  reviewStatus    String   @default("approved")
  reviewedAt      DateTime?
  reviewedBy      String?
  rejectReason    String?
  isFeatured      Boolean  @default(false)

  viewCount       Int      @default(0)

  // M8.3 扩展
  tags               String?
  aiReviewedAt       DateTime?
  aiReviewResult     String?
  aiReviewConfidence Float?
  aiReviewReason     String?
  humanOverride      String?
  isAiGenerated      Boolean @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  comments        CommunityComment[]
  sensitiveHits   CommunitySensitiveHit[] @relation("PostSensitive")
  moderationLogs  CommunityModerationLog[]

  @@index([groupId, reviewStatus, createdAt])
  @@index([reviewStatus, createdAt])
  @@index([isFeatured, createdAt])
}

model CommunityComment {
  id            String   @id @default(cuid())
  postId        String
  post          CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorUserId  String?
  authorUser    User?    @relation("UserComments", fields: [authorUserId], references: [id])
  authorRole    String   @default("patient")
  isAnonymous   Boolean  @default(false)
  content       String 

  reviewStatus  String   @default("approved")
  reviewedAt    DateTime?
  reviewedBy    String?

  // M8.3 扩展
  aiReviewedAt       DateTime?
  aiReviewResult     String?
  aiReviewConfidence Float?
  aiReviewReason     String?
  humanOverride      String?
  isAiGenerated      Boolean @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sensitiveHits CommunitySensitiveHit[] @relation("CommentSensitive")

  @@index([postId, createdAt])
}

model CommunitySensitiveHit {
  id          String   @id @default(cuid())
  postId      String?
  post        CommunityPost? @relation("PostSensitive", fields: [postId], references: [id], onDelete: Cascade)
  commentId   String?
  comment     CommunityComment? @relation("CommentSensitive", fields: [commentId], references: [id], onDelete: Cascade)
  keyword     String
  riskType    String
  riskLevel   String
  snippet     String 
  createdAt   DateTime @default(now())

  @@index([postId])
  @@index([commentId])
  @@index([riskType])
}

model CommunityModerationLog {
  id          String   @id @default(cuid())
  postId      String?
  post        CommunityPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId   String?
  action      String
  operatorId  String?
  reason      String?
  createdAt   DateTime @default(now())

  @@index([postId])
}

// M6 · 敏感词词库（后台化管理）
model SensitiveWord {
  id         String   @id @default(cuid())
  keyword    String   @unique
  riskType   String
  riskLevel  String
  isEnabled  Boolean  @default(true)
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isEnabled, riskLevel])
}

// M4 · FAQ：患者高频问题
model FaqArticle {
  id          String   @id @default(cuid())
  slug        String   @unique
  question    String
  answer      String 
  category    String   @default("general")
  tags        String?
  order       Int      @default(100)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, category, order])
}

// M3 · 我的报名
model Application {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trialId         String
  trial           ClinicalTrial @relation("TrialApplications", fields: [trialId], references: [id], onDelete: Cascade)
  leadId          String?  @unique
  lead            Lead?    @relation("LeadApplication", fields: [leadId], references: [id])

  stage           String   @default("submitted")
  stageChangedAt  DateTime @default(now())
  nextAction      String?
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([trialId, stage])
}

// ========== M8.1 · 反爬 / 封锁 / 图片素材库 ==========

// 用户行为日志（游客用 guestToken，登录用 userId）
model UserBehaviorLog {
  id          String   @id @default(cuid())
  userId      String?
  guestToken  String?
  action      String   // trial_detail_view / prescreen_start / ...
  targetType  String?
  targetId    String?
  userAgent   String?
  ipHash      String?  // IP 哈希，不落盘明文
  createdAt   DateTime @default(now())

  @@index([userId, action, createdAt])
  @@index([guestToken, action, createdAt])
  @@index([action, createdAt])
}

// 账号封锁（一名 user 同时最多一条，解锁后保留历史）
model AccountLock {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  reason          String    // 友好文案 "30min内查看20条试验详情（反爬规则）"
  triggeredBy     String?   // 规则名 "rate_limit:trial_detail_view"
  lockedAt        DateTime  @default(now())

  unlockedAt      DateTime?
  unlockedBy      String?   // OperatorUser.id
  unlockReason    String?

  appealText      String?
  appealedAt      DateTime?
  appealStatus    String    @default("none") // none/pending/approved/rejected
  appealReplyText String?
  appealHandledBy String?
  appealHandledAt DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([appealStatus, createdAt])
  @@index([unlockedAt])
}

// 图片素材库（骨架，仅元数据；软删除 via isEnabled）
model MediaAsset {
  id           String   @id @default(cuid())
  filename     String   // 存盘文件名（cuid.ext）
  originalName String
  url          String   // 对外 URL  /media/{category}/xxx.ext
  category     String   // hero / community / trial / faq / avatar / step
  width        Int?
  height       Int?
  sizeBytes    Int?
  mimeType     String?
  note         String?
  uploadedBy   String?  // OperatorUser.id
  isEnabled    Boolean  @default(true)
  overlayLabel String?  // M8.4 新增：hero 轮播左下角徽标（"真实研究中心"）；非 hero 位可空
  overlayText  String?  // M8.4 新增：hero 轮播左下角正文（"北京协和医院 · 乳腺肿瘤门诊"）；非 hero 位可空
  createdAt    DateTime @default(now())

  @@index([category, isEnabled, createdAt])
}

// ========== M8.2 · 试验预筛表单 + AI 预筛生成 + LLM 日志 ==========

// 一条 ClinicalTrial 对应 0..1 条 Form
model TrialPrescreenForm {
  id            String   @id @default(cuid())
  trialId       String   @unique
  trial         ClinicalTrial @relation(fields: [trialId], references: [id], onDelete: Cascade)

  version       Int      @default(1)      // 每次大改 +1，便于追溯
  isPublished   Boolean  @default(false)  // 未发布时 /prescreen 降级到通用版
  title         String?
  description   String?
  successMessage String?

  generatedBy   String?                    // "ai" / "human" / "ai-then-edited"
  generatedAt   DateTime?

  items         TrialPrescreenFormItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isPublished])
}

// 字段定义
model TrialPrescreenFormItem {
  id            String   @id @default(cuid())
  formId        String
  form          TrialPrescreenForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  fieldKey      String                // Lead.projectAnswers 的 key（英文 snake_case）
  label         String                // 中文问题
  helpText      String?
  fieldType     String                // single / multi / text / textarea / number / date / agree
  options       String?               // JSON: [{value,label},...]
  placeholder   String?
  defaultValue  String?               // JSON
  isRequired    Boolean  @default(false)
  minValue      Float?
  maxValue      Float?
  regex         String?
  errorMessage  String?
  showWhen      String?               // JSON: {fieldKey, op, value}  op=eq|neq|in|notIn

  sortOrder     Int      @default(100)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([formId, sortOrder])
}

// LLM 调用日志（供 /admin/llm-logs）
model LlmCallLog {
  id               String   @id @default(cuid())
  operatorId       String?
  scenario         String             // prescreen_generate / match_assistant / community_review / disease_analysis / llm_sanity
  provider         String             // deepseek / mock
  model            String?            // deepseek-chat / mock
  promptHash       String             // sha256 前 16 位
  promptChars      Int
  responseChars    Int?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  estimatedCostCny Float?             // 精度到 0.0001
  durationMs       Int?
  status           String             // success / error / timeout
  errorMessage     String?
  createdAt        DateTime @default(now())

  @@index([scenario, createdAt])
  @@index([provider, status, createdAt])
}

// ========== M8.3 · 账号体系 + 社区重做 ==========

model UserMedicalRecord {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename     String
  originalName String
  url          String
  mimeType     String
  sizeBytes    Int
  note         String?
  isReviewed   Boolean   @default(false)
  reviewedAt   DateTime?
  reviewedBy   String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([isReviewed, createdAt])
  @@index([deletedAt])
}

model UserGroupMembership {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId             String
  group               CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  joinedAt            DateTime  @default(now())
  leftAt              DateTime?
  joinSymptoms        String?
  joinDiseaseTagsJson String?

  @@unique([userId, groupId])
  @@index([userId, leftAt])
  @@index([groupId, leftAt])
}

model MatchAssistantSession {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  transcript            String
  symptomsSnapshot      String?
  recommendedTrialIds   String?
  recommendedDepartment String?
  symptomDirection      String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId, createdAt])
}

model AiAccountTemplate {
  id              String    @id @default(cuid())
  scenario        String    @unique
  isEnabled       Boolean   @default(true)
  triggerRule     String
  contentTemplate String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
